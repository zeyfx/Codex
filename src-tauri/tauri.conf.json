{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "codex",
  "version": "0.1.0",
  "identifier": "com.vortex.codex",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex",
        "width": 1100,
        "height": 680,
        "minWidth": 940,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/SEU_USER/codex/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzMTI2ODJGNjI1RjcwRTEKUldUaGNGOWlMMmdTVTV3aFgyN1ZwSmo1d0ozN2NZSGc0VTFCeHZsUlc4VUluYVFPRXJsanNSaS8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
