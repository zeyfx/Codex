# Ignore dependencies
node_modules/
.pnp
.pnp.js

# Ignore builds
dist/
out/
build/
src-tauri/target/

# Ignore env config
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore OS files
.DS_Store
Thumbs.db
desktop.ini

# Ignore IDE / Editor configs
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# CRITICAL: Ignore Tauri private secrets for Updater
*.key
*.key.pub
src-tauri/*.key
src-tauri/*.key.pub

# Temp files
*.tmp
Coverage/
.nyc_output/
